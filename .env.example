# --- General AI Configuration ---
# Your Google AI Studio API Key (for Gemini 1.5 Flash)
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Messaging (Redis) ---
# For local demo, use REDIS_HOST=localhost and REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: REDIS_PASSWORD=your_redis_password
# Optional: REDIS_URL=redis://localhost:6379

# --- Database (MongoDB) ---
# Your MongoDB connection string (Local instance or Atlas)
MONGODB_URI=mongodb://localhost:27017/image_annotation

# --- Storage ---
# Path where uploaded images will be stored
IMAGE_STORE_PATH=image_store/
